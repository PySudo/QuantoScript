# QuantoScript v0.1.0 Feature Validation Test Suiteprint("=== 1. Basic Syntax ===")x = 42pi = 3.14name = "hello"flag = truenothing = nullprint(x)print(pi)print(name)print(flag)print(nothing)assert_eq(x, 42)assert_eq(pi, 3.14)assert_eq(name, "hello")assert_eq(flag, true)assert_eq(nothing, null)print("=== 2. Types ===")assert_eq(type(42), "int")assert_eq(type(3.14), "float")assert_eq(type("hi"), "string")assert_eq(type(true), "bool")assert_eq(type(null), "null")assert_eq(type([1,2]), "list")assert_eq(type({"a":1}), "map")print("=== 3. 1-Based Indexing ===")items = [10, 20, 30]assert_eq(items[1], 10)assert_eq(items[2], 20)assert_eq(items[3], 30)s = "hello"assert_eq(s[1], "h")assert_eq(s[5], "o")print("=== 4. Arithmetic Operators ===")assert_eq(3 + 4, 7)assert_eq(10 - 3, 7)assert_eq(3 * 4, 12)assert_eq(10 / 3, 3)assert_eq(10 % 3, 1)print("=== 5. Comparison Operators ===")assert_eq(5 == 5, true)assert_eq(5 != 3, true)assert_eq(3 < 5, true)assert_eq(5 > 3, true)assert_eq(3 <= 3, true)assert_eq(5 >= 5, true)print("=== 6. Logical Operators ===")assert_eq(true and true, true)assert_eq(true or false, true)assert_eq(true and true, true)print("=== 7. Compound Assignment ===")x = 10x += 5assert_eq(x, 15)x -= 3assert_eq(x, 12)x *= 2assert_eq(x, 24)x /= 4assert_eq(x, 6)x %= 4assert_eq(x, 2)print("=== 8. Control Flow - if/maybe/else ===")x = 15if x > 10 {    assert_eq(x > 10, true)} maybe x > 5 {    assert_eq(x > 5, true)} else {    assert_eq(true, false)}print("=== 9. Control Flow - while ===")total = 0i = 0while i < 5 {    total = total + i    i = i + 1}assert_eq(total, 10)print("=== 10. Control Flow - repeat ===")count = 0repeat 5 {    count = count + 1}assert_eq(count, 5)print("=== 11. Functions ===")func add(a, b) {    return a + b}assert_eq(add(3, 4), 7)func factorial(n) {    if n <= 1 {        return 1    }    return n * factorial(n - 1)}assert_eq(factorial(5), 120)print("=== 13. Lambda Expressions ===")double = fn(x) -> x * 2assert_eq(double(5), 10)add = fn(a, b) -> a + bassert_eq(add(3, 4), 7)print("=== 14. Classes ===")class Person {    init(name) {        self.name = name    }    greet() {        return self.name    }}p = Person("Alice")assert_eq(p.greet(), "Alice")class Counter {    init() {        self.count = 0    }    inc() {        self.count = self.count + 1    }    get() {        return self.count    }}c = Counter()c.inc()c.inc()assert_eq(c.get(), 2)a = Counter()b = ab.inc()assert_eq(a.get(), 1)print("=== 15. Lists ===")nums = [3, 1, 4, 1, 5]assert_eq(nums[1], 3)assert_eq(len(nums), 5)nums.extend([6])assert_eq(len(nums), 6)assert_eq(nums.contains(4), true)assert_eq(nums.sum(), 20)print("=== 16. Maps ===")m = {"name": "QS", "version": 1}assert_eq(m["name"], "QS")assert_eq(m.keys().count, 2)assert_eq(m.has("name"), true)m.remove("name")assert_eq(m.has("name"), false)print("=== 17. String Methods ===")s = "hello world"assert_eq(s.contains("world"), true)assert_eq(s.replace("world", "QS"), "hello QS")assert_eq(s.startsWith("hello"), true)assert_eq(s.endsWith("world"), true)assert_eq(s.title(), "Hello World")print("=== 18. Exception Handling ===")try {    x = 10 / 0} oops e {    assert_eq(e, "cannot divide by zero")}func bad() {    oops("from function")}try {    bad()} oops e {    assert_eq(e, "from function")}print("=== 19. Imports (math) ===")from "stdlib/math.qs" import min, max, clampassert_eq(min([3, 7, 1]), 1)assert_eq(max([3, 7, 1]), 7)assert_eq(clamp(5, 1, 3), 3)print("=== 20. Built-in Functions ===")assert_eq(len("hi"), 2)assert_eq(len([1, 2]), 2)assert_eq(str(42), "42")assert_eq(type(42), "int")assert_eq(type(3.14), "float")assert_eq(type("hi"), "string")assert_eq(type(true), "bool")print("=== 21. String Operations ===")from "stdlib/text.qs" import upper, lower, splitassert_eq(upper("hello"), "HELLO")assert_eq(lower("HELLO"), "hello")assert_eq(split("a,b,c", ",").count, 3)print("=== ALL FEATURE VALIDATION TESTS PASSED ===")