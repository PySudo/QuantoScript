# Built-in print

name = "Quanto"
score = 2 + 3
items = ["a", "b", "c"]

print(name)
print(score)
print(items)

# print can take many values, like Python.
print("name:", name, "score:", score)

# Direct strings print without quotes.
print("hello")

# Strings inside lists print with quotes.
print(["hello"])

